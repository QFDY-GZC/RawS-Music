<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RawSMusic" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:colorBackground">@color/page_bg</item>
        <item name="android:windowBackground">@color/page_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- 设置页面主题：使用 Theme.DeviceDefault 系统默认行为 -->
    <style name="SettingsActivityTheme" parent="@android:style/Theme.DeviceDefault.Light.NoActionBar">
        <item name="android:windowBackground">@color/settings_page_bg</item>
        <item name="android:colorBackground">@color/settings_page_bg</item>
        <item name="android:statusBarColor">@color/settings_page_bg</item>
        <item name="android:navigationBarColor">@color/settings_page_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
