    <string name="transition_manual_title">手动改变音轨</string>
    <string name="transition_manual_summary">设置上一首、下一首和点选歌曲时的切换方式。</string>
    <string name="transition_manual_none_title">无淡入淡出</string>
    <string name="transition_manual_none_desc">立即切换音轨，适合追求最低延迟或测试严格 bit-perfect 的场景。</string>
    <string name="transition_manual_short_title">短时交叉渐隐</string>
    <string name="transition_manual_short_desc">先让当前音轨短时淡出，再让下一首从静音淡入。</string>
    <string name="transition_manual_crossfade_title">交叉淡入淡出</string>
    <string name="transition_manual_crossfade_desc">当前音轨和下一首音轨重叠混合；仅在解码后的输出格式兼容时启用。</string>
    <string name="transition_manual_duration_title">手动过渡长度</string>
    <string name="transition_manual_duration_desc">用于短时手动渐隐和手动交叉淡入淡出，默认 400 ms。</string>
    <string name="transition_transport_title">播放、暂停与停止</string>
    <string name="transition_transport_summary">让用户触发的播放开始和结束更平滑。</string>
    <string name="transition_transport_enable_title">启用播放控制淡入淡出</string>
    <string name="transition_transport_enable_desc">播放/恢复时淡入，暂停或停止前先淡出。</string>
    <string name="transition_transport_duration_title">播放控制淡入淡出长度</string>
    <string name="transition_transport_duration_desc">用于播放、暂停和停止，默认 400 ms。</string>
    <string name="transition_seek_title">调整进度淡入淡出</string>
    <string name="transition_seek_summary">拖动播放进度时减少爆音、电流声和旧缓冲残留。</string>
    <string name="transition_seek_enable_title">启用 seek 淡入淡出</string>
    <string name="transition_seek_enable_desc">seek 前淡出，清理旧缓冲，然后在新位置开始后淡入。</string>
    <string name="transition_seek_duration_title">seek 淡入淡出长度</string>
    <string name="transition_seek_duration_desc">比播放控制更短，保证拖动进度仍然跟手，默认 100 ms。</string>
